# ─────────────────────────────────────────────
# EchoHealth Server — 环境变量
# 复制本文件为 .env，填写真实值后启动服务
# ─────────────────────────────────────────────

# ── 服务 ──────────────────────────────────────
PORT=3000

# ── 数据库（PostgreSQL）────────────────────────
# 本地 Docker：docker run -d --name pg -e POSTGRES_PASSWORD=pass -e POSTGRES_DB=echohealth -p 5432:5432 postgres:16
DATABASE_URL=postgresql://postgres:pass@localhost:5432/echohealth

# ── Redis ─────────────────────────────────────
# 本地 Docker：docker run -d --name redis -p 6379:6379 redis:7
REDIS_URL=redis://localhost:6379

# ── LLM（二选一，OPENROUTER_API_KEY 优先）──────
# 测试阶段推荐：OpenRouter 免费模型（无需付费）
# 注册：https://openrouter.ai → 复制 API Key
OPENROUTER_API_KEY=
# 默认使用上下文最长的免费模型（1M tokens，支持中文）
# 如需更换模型，取消注释并修改：
# OPENROUTER_MODEL=qwen/qwen3-coder:free

# 生产阶段：Anthropic Claude API
# 注册：https://console.anthropic.com → 复制 API Key
CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6

# ── 腾讯云（OCR + COS）────────────────────────
# 控制台：https://console.cloud.tencent.com/cam/capi
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_OCR_REGION=ap-guangzhou

# COS 存储桶（格式：bucketname-appid，例：echohealth-1234567890）
# 控制台：https://console.cloud.tencent.com/cos/bucket
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou

# ── 微信小程序 ────────────────────────────────
# 微信公众平台：https://mp.weixin.qq.com → 开发 → 开发管理 → 开发设置
WX_APPID=
WX_SECRET=

# ── 微信支付（暂未启用）─────────────────────────
WECHAT_PAY_MCH_ID=
WECHAT_PAY_KEY=

# ── Remotion 渲染（可选）─────────────────────────
# 指定 Chrome 路径（默认使用系统 Chrome）
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
